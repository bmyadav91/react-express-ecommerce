enum OrderStatus {
    PENDING
    COMPLETED
    CANCELLED
}

model Order {
    id           String      @id @default(uuid())
    total_amount Decimal     @db.Decimal(10, 2)
    status       OrderStatus @default(PENDING)
    created_at   DateTime    @default(now())

    // Foreign Key Field
    user_id      String
    
    // Relation Definition
    // We keep the relation here so Prisma knows user_id points to User.id
    user         User        @relation(fields: [user_id], references: [id])

    data        Json

    @@index([user_id])
    @@map("orders")
}